{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "kintone Developer Platform",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/api-reference/introduction",
          "icon": "code"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/kintone",
          "icon": "github"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "en/introduction",
                  "en/quickstart",
                  "en/development"
                ]
              },
              {
                "group": "Customization",
                "pages": [
                  "en/essentials/settings",
                  "en/essentials/navigation"
                ]
              },
              {
                "group": "Writing content",
                "pages": [
                  "en/essentials/markdown",
                  "en/essentials/code",
                  "en/essentials/images",
                  "en/essentials/reusable-snippets"
                ]
              },
              {
                "group": "AI tools",
                "pages": [
                  "en/ai-tools/cursor",
                  "en/ai-tools/claude-code",
                  "en/ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "REST API reference",
                "openapi": "openapi.yaml"
              },
              {
                "group": "JS API reference",
                "pages": [
                  {
                    "group": "Events",
                    "pages": [
                      "en/js-api/event/event-handling"
                    ]
                  },
                  {
                    "group": "General",
                    "pages": [
                      "en/js-api/general/get-login-user"
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "ja",
        "tabs": [
          {
            "tab": "ガイド",
            "groups": [
              {
                "group": "はじめに",
                "pages": [
                  "ja/introduction",
                  "ja/quickstart",
                  "ja/development"
                ]
              },
              {
                "group": "カスタマイズ",
                "pages": [
                  "ja/essentials/settings",
                  "ja/essentials/navigation"
                ]
              },
              {
                "group": "コンテンツの作成",
                "pages": [
                  "ja/essentials/markdown",
                  "ja/essentials/code",
                  "ja/essentials/images",
                  "ja/essentials/reusable-snippets"
                ]
              },
              {
                "group": "AIツール",
                "pages": [
                  "ja/ai-tools/cursor",
                  "ja/ai-tools/claude-code",
                  "ja/ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "APIリファレンス",
            "groups": [
              {
                "group": "APIドキュメント",
                "pages": [
                  "ja/api-reference/introduction"
                ]
              },
              {
                "group": "エンドポイント例",
                "pages": [
                  "ja/api-reference/endpoint/get",
                  "ja/api-reference/endpoint/create",
                  "ja/api-reference/endpoint/delete",
                  "ja/api-reference/endpoint/webhook"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "/en/home"
      },
      {
        "label": "Community",
        "href": "https://developer.cybozu.io/hc/en-us/community/topics"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "redirects": [
    {
      "source": "/home",
      "destination": "/index"
    }
  ]
}